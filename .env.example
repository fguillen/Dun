# Copy this file to .env (gitignored) and fill in real values.

# Database (production only — dev/test fall back to the names in database.yml)
# DATABASE_URL=postgres://user:pass@host:5432/dun_production

# Rails secret (production only; dev uses config/master.key)
# RAILS_MASTER_KEY=

# Bootstrap admin — db/seeds.rb find-or-creates this Admin.
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_NAME="First Admin"

# Magic link mailer from-address.
MAGIC_LINK_FROM_EMAIL=no-reply@example.com

# OpenTelemetry exporter. Leave unset (or empty) to disable telemetry.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=dun-backend

# Solid Queue worker concurrency (Procfile.dev / production).
# JOB_CONCURRENCY=1
